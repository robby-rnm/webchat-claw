# OpenClaw Gateway Configuration
# Copy to .env and fill in your values

# Gateway URL (e.g., http://localhost:3000 or https://your-gateway.com)
OPENCLAW_URL=http://localhost:3000

# API Key from OpenClaw (get from config or admin)
OPENCLAW_API_KEY=your_api_key_here

# Optional: Session label for conversation persistence
SESSION_LABEL=my-app-client
